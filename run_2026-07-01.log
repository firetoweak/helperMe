, "content": "", "kind": "context"}, {"line": 76, "content": "    root, err = _resolve_in_workspace(raw.path, expect=\"dir\")", "kind": "context"}, {"line": 77, "content": "    if err:", "kind": "context"}, {"line": 78, "content": "        return err", "kind": "context"}, {"line": 79, "content": "", "kind": "context"}, {"line": 80, "content": "    cmd = [\"fd\", \"-g\", raw.pattern, \"-a\", str(root)]", "kind": "context"}, {"line": 81, "content": "    if raw.max_depth is not None:", "kind": "context"}, {"line": 82, "content": "        cmd.extend([\"--max-depth\", str(raw.max_depth)])", "kind": "context"}, {"line": 83, "content": "    if raw.kind == \"dir\":", "kind": "context"}, {"line": 84, "content": "        cmd.extend([\"-t\", \"d\"])", "kind": "context"}, {"line": 85, "content": "    elif raw.kind == \"file\":", "kind": "context"}, {"line": 86, "content": "        cmd.extend([\"-t\", \"f\"])", "kind": "context"}, {"line": 87, "content": "    ", "kind": "context"}, {"line": 88, "content": "    proc = subprocess.run(cmd, capture_output=True, text=True, encoding=\"utf-8\")", "kind": "context"}, {"line": 89, "content": "", "kind": "context"}, {"line": 90, "content": "    if proc.returncode == 2:", "kind": "context"}, {"line": 91, "content": "        return {\"error\": proc.stderr.strip() or \"fd 执行失败\"}", "kind": "context"}, {"line": 92, "content": "", "kind": "context"}, {"line": 93, "content": "    ws = WORKSPACE.resolve()", "kind": "context"}, {"line": 94, "content": "    lines = [ln for ln in proc.stdout.splitlines() if ln.strip()]", "kind": "context"}, {"line": 95, "content": "    total = len(lines)", "kind": "context"}, {"line": 96, "content": "    truncated = total > raw.max_results", "kind": "context"}, {"line": 97, "content": "    lines = lines[:raw.max_results]", "kind": "context"}, {"line": 98, "content": "    matches = []", "kind": "context"}, {"line": 99, "content": "    for line in lines:", "kind": "context"}, {"line": 100, "content": "        abs_pat